"""Plan configuration — holidays, evolution tracks.

Copy this file to plan_config.py and customize for your cellar.
"""

# Holiday anchors: (name, approximate month, approximate day)
# The plan generator finds the nearest week to each date and assigns a special bottle.
HOLIDAYS: list[tuple[str, int, int]] = [
    ("Thanksgiving", 11, 26),  # late November
    ("Christmas", 12, 18),  # mid December
    ("New Year's Eve", 12, 28),  # late December
    ("Valentine's Day", 2, 14),  # mid February
    ("4th of July", 7, 4),  # early July
    # Add your own — examples:
    # ("Anniversary", 5, 28),
    # ("Birthday", 10, 15),
]

# Evolution tracking: open one bottle per year from each label to monitor
# how a wine develops across vintages. The generator picks the most urgent
# vintage within the drinking window and schedules it in the preferred month.
#
# Fields:
#   label             — display name for the evolution track
#   name_fragment     — lowercase substring matched against wine names in inventory
#   season_months     — (start_month, end_month) range for scheduling
#   preferred_month   — ideal month within the range
#   occasion_template — format string; {occasion} is replaced with the holiday name
#                       if the evolution slot overlaps a holiday
EVOLUTION_TRACKS: list[dict] = [
    # Example: track a specific wine label across vintages
    # {
    #     "label": "Laurène",
    #     "name_fragment": "laurène",
    #     "season_months": (10, 11),
    #     "preferred_month": 11,
    #     "occasion_template": "{occasion} — Laurène evolution",
    # },
]
