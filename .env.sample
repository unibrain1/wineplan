# 1Password Service Account Token (or set in system environment)
# OP_SERVICE_ACCOUNT_TOKEN=

# CellarTracker credentials (1Password secret references)
USERNAME="op://<vault>/<item>/username"
PASSWORD="op://<vault>/<item>/password"

# Google Calendar secret .ics URL for menu plan
GOOGLE_CALENDAR_ICS_URL=https://calendar.google.com/calendar/ical/<calendar-id>/private-<token>/basic.ics

# Claude Code OAuth token for tasting note generation (from: claude setup-token)
CLAUDE_CODE_OAUTH_TOKEN=

# Healthchecks.io ping key (1Password secret reference)
HEALTHCHECK_PING_KEY="op://<vault>/<item>/ping_key"
